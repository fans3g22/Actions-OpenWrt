# 基础架构
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y

# 关键：选择 U-Boot 布局的红米 AX6000
# 注意：在某些源码库（如 hanwckf）中，它是单独的一个 Profile
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_redmi-router-ax6000-uboot-mod=y


# --- 核心组件 ---
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_kmod-mt7986-firmware=y

# --- 特殊功能插件 (基于您的列表) ---
CONFIG_PACKAGE_luci-app-adguardhome=y  # 广告拦截
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-nikki=y        # Nikki (代理工具)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y


CONFIG_PACKAGE_wpad-openssl=y



# --- 修复/默认 ---
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ipv6helper=y

# --- 主题 (根据列表) ---
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-openwrt=y
# 您的列表里有 luci-app-advancedplus (Kucat 设置)，如果您需要 Kucat 主题，请手动把下面这行前面的 # 去掉
# CONFIG_PACKAGE_luci-theme-kucat=y
